# Supabase Development (Get these from your Supabase Dashboard or local CLI)
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Database (Postgres; used by the extension for LangGraph checkpoint tables via PostgresSaver)
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Storage (S3 Compatibility)
S3_ENDPOINT=http://127.0.0.1:54321/storage/v1/s3
S3_ACCESS_KEY=your_s3_access_key
S3_SECRET_KEY=your_s3_secret_key
S3_REGION=local

# System Configuration
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8000,http://127.0.0.1:8000

# Tools
SUPABASE_STUDIO_URL=http://127.0.0.1:54323
SUPABASE_MAILPIT_URL=http://127.0.0.1:54324

# 🧠 Lokal Agent LLM Configuration
# Base configuration for the LLM backend (Ollama/OpenAI compatible)
LOKAL_AGENT_API_URL=http://127.0.0.1:11434/v1
LOKAL_AGENT_API_KEY=""

# Layer Specfic Models (Adjust based on local Ollama / Cloud availability)
# LAYER 0: Conversation & Intent Gateway — must be a model Ollama exposes with tool support (Llama 3.1, Qwen coder, etc.; Gemma often fails with "does not support tools")
LOKAL_AGENT_LAYER0_MODEL=llama3.1:8b-instruct-q4_K_M

# LAYER 1: Intent Routing & Planning (High reasoning capability)
LOKAL_AGENT_LAYER1_MODEL=llama3.1:8b-instruct-q4_K_M

# LAYER 2+: Execution & Validation (Reliable logical reasoning)
LOKAL_AGENT_EXECUTION_MODEL=llama3.1:8b-instruct-q4_K_M
