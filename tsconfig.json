{
  "compilerOptions": {
    "module": "NodeNext",
    "target": "ESNext",
    "lib": ["ESNext", "DOM"],
    "sourceMap": true,
    "rootDir": "src",
    "outDir": "dist",
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@core/*": ["src/core/*"],
      "@config/*": ["src/services/config/*"],
      "@llms/*": ["src/services/llms/*"],
      "@file-service/*": ["src/services/file-service/*"],
      "@chat/*": ["src/services/chat/*"],
      "@webview/*": ["src/services/webview/*"],
      "@commands/*": ["src/commands/*"],
      "@lokal-types/*": ["src/types/*"],
      "@persistence/*": ["src/services/persistence/*"],
      "@/*": ["src/*"]
    },
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", ".vscode-test"]
}
